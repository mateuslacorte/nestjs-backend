# Application Configuration
APP_NAME=Backend
NODE_ENV=development
HOST=http://localhost
PORT=3000
# Public origin for wiki SEO / Open Graph (no trailing slash)
# APP_URL=https://nestjs.lacorte.dev
API_VERSION=v1
# Extra CORS origins only (comma-separated). Self origins from HOST+PORT and APP_URL
# (wiki, swagger, API, GraphQL on this process) are always allowed — do not list them here.
# Example: SPA / mobile web client on another port or domain
# CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=

# Graylog Configuration (GELF HTTP input)
LOG_LEVEL=info
GRAYLOG_ENABLED=true
GRAYLOG_ENDPOINT=http://localhost:12201/gelf
GRAYLOG_HOST=backend
GRAYLOG_FACILITY=nestjs
GRAYLOG_TIMEOUT=3000

# Blowfish Configuration
BCRYPT_HASH_FACTOR=16

# GraphQL Configuration
GRAPHQL_AUTO_SCHEMA_FILE=true
GRAPHQL_PLAYGROUND=true

# Json Web Token Configuration
JWT_SECRET=secret
JWT_EXPIRATION_TIME=1h
JWT_REFRESH_SECRET=secret_refresh
JWT_REFRESH_EXPIRATION_TIME=7d
# Random seconds added to each token TTL (0 … N) to avoid mass simultaneous expiry
JWT_JITTER_SECONDS=60

# Kafka Configuration
KAFKA_CLIENT_ID=my-client
KAFKA_BROKERS=localhost:9092,localhost:9093
KAFKA_GROUP_ID=my-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=my_username
KAFKA_SASL_PASSWORD=my_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DB=0
REDIS_TTL=3600

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/mongo
MONGO_POOL_MAX=10
MONGO_POOL_MIN=0
MONGO_POOL_IDLE=30000
MONGO_POOL_TIMEOUT=5000

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Deixe false em produção e use migrations; true apenas para bootstrap local
POSTGRES_SYNCHRONIZE=false
POSTGRES_POOL_MAX=10
POSTGRES_POOL_MIN=2
POSTGRES_POOL_IDLE=30000
POSTGRES_POOL_TIMEOUT=5000

# SMTP Configuration
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# MailHog (docker compose de teste)
# UI: http://localhost:8025 | SMTP: mailhog:1025
# SMTP_HOST=mailhog
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=false
# SMTP_USER=
# SMTP_PASSWORD=

# Evolution API Configuration
EVOLUTION_API_URL=https://evolution-api.example.com
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_API_INSTANCE=your_evolution_api_instance

# Google OAuth2 (optional — Authorization Code Exchange)
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# Comma-separated allowed redirect URL prefixes (mobile deep link and/or web)
GOOGLE_REDIRECT_ALLOWLIST=myapp://success,http://localhost:5173/auth/callback
# Comma-separated Role values for new Google users (e.g. user or user,manager). Empty = []
GOOGLE_OAUTH_DEFAULT_ROLES=

# Facebook OAuth2 (optional — Authorization Code Exchange)
FACEBOOK_AUTH_ENABLED=false
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback
# Comma-separated allowed redirect URL prefixes (mobile deep link and/or web)
FACEBOOK_REDIRECT_ALLOWLIST=myapp://success,http://localhost:5173/auth/callback
# Comma-separated Role values for new Facebook users (e.g. user or user,manager). Empty = []
FACEBOOK_OAUTH_DEFAULT_ROLES=

# MinIO API Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=atalahub

# Graylog (usado pelo docker-compose)
# GRAYLOG_PASSWORD_SECRET: mínimo 16 caracteres
GRAYLOG_PASSWORD_SECRET=changemechangemechangeme
# SHA-256 da senha do usuário admin (o valor abaixo corresponde a "admin")
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918