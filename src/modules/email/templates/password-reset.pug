extends layout

block content
  h3(style='margin:0 0 16px;font-size:20px;color:#0f172a;') Password Reset
  p(style='margin:0 0 12px;') You requested a password reset.
  p(style='margin:0 0 16px;') Use the code below to reset your password:
  p(style='margin:0 0 16px;')
    strong(style='font-size:24px;letter-spacing:4px;color:#2563eb;')= token
  p(style='margin:0 0 16px;') This code expires in 1 hour.
  p(style='margin:20px 0 0;color:#666;font-size:12px;') If you did not request a password reset, please ignore this email.
