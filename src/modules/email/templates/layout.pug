doctype html
html(lang='en')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title= subject || 'Notification'
  body(style='margin:0;padding:24px;font-family:Arial,Helvetica,sans-serif;color:#333;line-height:1.5;background:#f8fafc;')
    table(role='presentation' cellpadding='0' cellspacing='0' width='100%' style='max-width:560px;margin:0 auto;background:#ffffff;border:1px solid #e2e8f0;border-radius:8px;')
      tr
        td(style='padding:32px;')
          block content
