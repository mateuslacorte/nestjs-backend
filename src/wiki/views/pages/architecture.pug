extends ../layouts/main

block content
  //- Header
  .mb-12
    .inline-flex.items-center.gap-2.px-3.py-1.bg-indigo-50.rounded-full.text-indigo-700.text-sm.font-medium.mb-4
      svg(class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10")
      span= t('architecture.badge')
    h1(class="text-4xl font-bold text-gray-900 mb-4")
      | #{t('architecture.hero.titlePrefix')} 
      span.gradient-text= t('architecture.hero.titleHighlight')
    p(class="text-xl text-gray-600 max-w-3xl")
      = t('architecture.hero.subtitle')

  //- Stack Tecnológico Completo
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('architecture.techStack.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6")
        -
          const techCategories = [
            { key: 'framework', bg: 'from-red-50 to-red-100', iconColor: 'text-red-600' },
            { key: 'databases', bg: 'from-green-50 to-green-100', iconColor: 'text-green-600' },
            { key: 'cacheMessaging', bg: 'from-orange-50 to-orange-100', iconColor: 'text-orange-600' },
            { key: 'storageApis', bg: 'from-blue-50 to-blue-100', iconColor: 'text-blue-600' },
            { key: 'authentication', bg: 'from-purple-50 to-purple-100', iconColor: 'text-purple-600' },
            { key: 'services', bg: 'from-indigo-50 to-indigo-100', iconColor: 'text-indigo-600' }
          ]
        each category in techCategories
          div.p-4.bg-gradient-to-br.rounded-lg(class=category.bg)
            h3(class="font-semibold text-gray-900 mb-3")= t(`architecture.techStack.${category.key}.title`)
            ul.space-y-2.text-sm.text-gray-700
              each item in tm(`architecture.techStack.${category.key}.items`)
                li.flex.items-center.gap-2
                  svg(class=`w-4 h-4 ${category.iconColor}` fill="currentColor" viewBox="0 0 20 20")
                    path(fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd")
                  span= item

  //- Configurações e Environment Variables
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('architecture.config.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-6")
        != t('architecture.config.intro')
      
      div(class="grid grid-cols-1 md:grid-cols-2 gap-6")
        div
          h3(class="font-semibold text-gray-900 mb-4")= t('architecture.config.files.title')
          ul.space-y-2.text-sm.text-gray-700
            each text in tm('architecture.config.files.items')
              li!= text

        div
          h3(class="font-semibold text-gray-900 mb-4")= t('architecture.config.usage.title')
          .code-block
            .code-header
              span= t('architecture.config.usage.codeHeader.language')
              span= t('architecture.config.usage.codeHeader.context')
            .code-content
              pre.
                constructor(private configService: ConfigService) {}
                
                #{t('architecture.samples.accessConfig')}
                const mongoUri = this.configService.get<string>('database.mongoUri');
                const redisHost = this.configService.get<string>('redis.host');
                const jwtSecret = this.configService.get<string>('jwt.secret');

  //- Fluxo de Requisição
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('architecture.requestFlow.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      -
        const flowSteps = [
          'clientRequest', 'securityMiddleware', 'jwtAuth', 'rolesAuth',
          'cacheInterceptor', 'controller', 'serviceLayer', 'repositoryPattern',
          'logging', 'responseCache'
        ]
      each stepKey, index in flowSteps
        .flow-step(class=index < flowSteps.length - 1 ? 'mb-6' : '' data-step=index + 1)
          h3(class="font-semibold text-gray-900 mb-2")= t(`architecture.requestFlow.steps.${stepKey}.title`)
          p.text-gray-600!= t(`architecture.requestFlow.steps.${stepKey}.description`)

  //- Sistema de Cache
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('architecture.cache.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      h3(class="font-semibold text-gray-900 mb-4")= t('architecture.cache.howItWorks.title')
      p(class="text-gray-700 mb-6")
        != t('architecture.cache.howItWorks.description')

      div(class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6")
        div
          h4(class="font-semibold text-gray-900 mb-3")= t('architecture.cache.interceptors.title')
          ul.space-y-2.text-sm.text-gray-700
            li!= t('architecture.cache.interceptors.typeOrm')
            li!= t('architecture.cache.interceptors.mongoose')
            li!= t('architecture.cache.interceptors.service')

        div
          h4(class="font-semibold text-gray-900 mb-3")= t('architecture.cache.redisConfig.title')
          .code-block
            .code-header
              span= t('architecture.cache.redisConfig.codeHeader.label')
              span= t('architecture.cache.redisConfig.codeHeader.context')
            .code-content
              pre.
                REDIS_HOST=localhost
                REDIS_PORT=6379
                REDIS_PASSWORD=
                REDIS_DB=0
                REDIS_TTL=3600  #{t('architecture.samples.redisTtl')}

      h4(class="font-semibold text-gray-900 mb-3")= t('architecture.cache.flow.title')
      ol.space-y-3.text-sm.text-gray-700.list-decimal.list-inside
        each step in tm('architecture.cache.flow.steps')
          li= step

  //- Persistência e CQRS-ready
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('architecture.persistence.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      h3(class="font-semibold text-gray-900 mb-4")= t('architecture.persistence.templatePattern.title')
      p(class="text-gray-700 mb-6")
        != t('architecture.persistence.templatePattern.description')

      h3(class="font-semibold text-gray-900 mb-4")= t('architecture.persistence.connectionPools.title')
      p(class="text-gray-700 mb-4")
        != t('architecture.persistence.connectionPools.description')
      .code-block.mb-6
        .code-header
          span= t('architecture.persistence.connectionPools.codeHeader.label')
          span= t('architecture.persistence.connectionPools.codeHeader.context')
        .code-content
          pre.
            POSTGRES_POOL_MAX=10
            POSTGRES_POOL_MIN=2
            POSTGRES_POOL_IDLE=30000
            POSTGRES_POOL_TIMEOUT=5000

            MONGO_POOL_MAX=10
            MONGO_POOL_MIN=0
            MONGO_POOL_IDLE=30000
            MONGO_POOL_TIMEOUT=5000

      div(class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6")
        div.p-6.bg-blue-50.rounded-lg.border.border-blue-200
          h4(class="font-semibold text-blue-900 mb-3 flex items-center gap-2")
            svg(class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4")
            = t('architecture.persistence.postgres.title')
          ul.space-y-2.text-sm.text-blue-800
            each item in tm('architecture.persistence.postgres.items')
              li • 
                != item

        div.p-6.bg-green-50.rounded-lg.border.border-green-200
          h4(class="font-semibold text-green-900 mb-3 flex items-center gap-2")
            svg(class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4")
            = t('architecture.persistence.mongo.title')
          ul.space-y-2.text-sm.text-green-800
            each item in tm('architecture.persistence.mongo.items')
              li • 
                != item

      h4(class="font-semibold text-gray-900 mb-3")= t('architecture.persistence.singleDbExample.title')
      .code-block.mb-6
        .code-header
          span= t('architecture.persistence.singleDbExample.codeHeader.language')
          span= t('architecture.persistence.singleDbExample.codeHeader.context')
        .code-content
          pre.
            constructor(
              private readonly postgresRepo: ResourcePostgresRepository,
            ) {}

            async create(data: CreateResourceDto) {
              return this.postgresRepo.create(data);
            }

            async findAll() {
              return this.postgresRepo.findAll();
            }

      h4(class="font-semibold text-gray-900 mb-3")= t('architecture.persistence.cqrsExample.title')
      p(class="text-gray-700 mb-4")
        = t('architecture.persistence.cqrsExample.description')
      .code-block.mb-4
        .code-header
          span= t('architecture.persistence.cqrsExample.codeHeader.language')
          span= t('architecture.persistence.cqrsExample.codeHeader.context')
        .code-content
          pre.
            constructor(
              private readonly mongoRepo: ResourceMongoRepository,      #{t('architecture.samples.commands')}
              private readonly postgresRepo: ResourcePostgresRepository, #{t('architecture.samples.queries')}
            ) {}

            async create(data: CreateResourceDto) {
              const resource = await this.mongoRepo.create(data);
              #{t('architecture.samples.publishKafkaEvent')}
              return resource;
            }

            async findAll() {
              return this.postgresRepo.findAll();
            }

      .alert.alert-info
        svg(class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z")
        div
          p.font-medium.text-blue-900= t('architecture.persistence.alert.title')
          p.text-sm.text-blue-700= t('architecture.persistence.alert.description')

  //- Relacionamento entre Tecnologias
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('architecture.relationships.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      .mb-6
        h3(class="font-semibold text-gray-900 mb-4")= t('architecture.relationships.diagram.title')
        div(class="bg-gray-50 rounded-lg p-6")
          -
            const diagramNodes = tm('architecture.relationships.diagram.nodes')
            const topNodes = ['nestjs', 'mongo', 'postgres']
            const topColors = ['text-indigo-600', 'text-green-600', 'text-blue-600']
            const bottomNodes = ['redis', 'kafka', 'minio', 'graylog']
            const bottomColors = ['text-orange-600', 'text-purple-600', 'text-yellow-600', 'text-gray-700']
          div(class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center")
            each nodeKey, index in topNodes
              div.p-4.bg-white.rounded.border.border-gray-200
                div.text-2xl.font-bold.mb-2(class=topColors[index])= diagramNodes[nodeKey].label
                p.text-xs.text-gray-600= diagramNodes[nodeKey].subtitle
          div.text-center.my-4
            svg(class="w-6 h-6 text-gray-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3")
          div(class="grid grid-cols-1 md:grid-cols-4 gap-4 text-center")
            each nodeKey, index in bottomNodes
              div.p-4.bg-white.rounded.border.border-gray-200
                div.text-2xl.font-bold.mb-2(class=bottomColors[index])= diagramNodes[nodeKey].label
                p.text-xs.text-gray-600= diagramNodes[nodeKey].subtitle

      ul.space-y-4.text-gray-700
        each text in tm('architecture.relationships.items')
          li!= text
