extends ../layouts/main

block content
  .mb-12.max-w-2xl
    .inline-flex.items-center.gap-2.px-3.py-1.bg-red-50.rounded-full.text-red-800.text-sm.font-medium.mb-4
      span= statusCode || 500
    h1(class="text-4xl font-bold text-gray-900 mb-4")
      | #{t('errors.serverError.hero.titlePrefix')} 
      span.gradient-text= t('errors.serverError.hero.titleHighlight')
    p(class="text-xl text-gray-600 mb-8")
      = t('errors.serverError.hero.subtitle')

    .alert.alert-error.mb-8
      svg(class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z")
      div
        p.font-medium.text-red-900= t('errors.serverError.alert.title')
        p.text-sm.text-red-700= t('errors.serverError.alert.description')

    .flex.flex-wrap.gap-3
      a(href=wikiPath('') class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors")
        = t('errors.serverError.ctaHome')
      a(href="javascript:location.reload()" class="inline-flex items-center gap-2 border border-gray-300 text-gray-700 px-5 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors")
        = t('errors.serverError.ctaRetry')
