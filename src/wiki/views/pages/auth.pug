extends ../layouts/main

block content
  //- Header
  .mb-12
    .inline-flex.items-center.gap-2.px-3.py-1.bg-indigo-50.rounded-full.text-indigo-700.text-sm.font-medium.mb-4
      svg(class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
      span= t('auth.badge')
    h1(class="text-4xl font-bold text-gray-900 mb-4")
      | #{t('auth.hero.titlePrefix')} 
      span.gradient-text= t('auth.hero.titleHighlight')
    p(class="text-xl text-gray-600 max-w-3xl")
      = t('auth.hero.subtitle')

  //- Visão Geral
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.overview.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-6")
        != t('auth.overview.description')

      div(class="grid grid-cols-1 md:grid-cols-2 gap-6")
        div.p-6.bg-indigo-50.rounded-lg.border.border-indigo-200
          h3(class="font-semibold text-indigo-900 mb-3")= t('auth.overview.authentication.title')
          ul.space-y-2.text-sm.text-indigo-800
            each item in tm('auth.overview.authentication.items')
              li • #{item}

        div.p-6.bg-purple-50.rounded-lg.border.border-purple-200
          h3(class="font-semibold text-purple-900 mb-3")= t('auth.overview.authorization.title')
          ul.space-y-2.text-sm.text-purple-800
            each item in tm('auth.overview.authorization.items')
              li • #{item}

  //- Fluxo de Autenticação JWT
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.jwtFlow.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      .flow-step.mb-6(data-step="1")
        h3(class="font-semibold text-gray-900 mb-2")= t('auth.jwtFlow.steps.login.title')
        p.text-gray-600= t('auth.jwtFlow.steps.login.description')
        .code-block.mt-3
          .code-header
            span= t('auth.jwtFlow.steps.login.codeHeader.label')
            span= t('auth.jwtFlow.steps.login.codeHeader.context')
          .code-content
            pre.
              POST #{apiBasePath}/auth/login
              Content-Type: application/json
              
              {
                "email": "usuario@example.com",
                "password": "senha123"
              }

      .flow-step.mb-6(data-step="2")
        h3(class="font-semibold text-gray-900 mb-2")= t('auth.jwtFlow.steps.validateCredentials.title')
        p.text-gray-600
          != t('auth.jwtFlow.steps.validateCredentials.description')

      .flow-step.mb-6(data-step="3")
        h3(class="font-semibold text-gray-900 mb-2")= t('auth.jwtFlow.steps.generateTokens.title')
        p.text-gray-600
          != t('auth.jwtFlow.steps.generateTokens.description')
          ul.mt-2.ml-4.space-y-1.text-sm.text-gray-600
            li • 
              != t('auth.jwtFlow.steps.generateTokens.accessToken')
            li • 
              != t('auth.jwtFlow.steps.generateTokens.refreshToken')
        .code-block.mt-3
          .code-header
            span= t('auth.jwtFlow.steps.generateTokens.codeHeader.label')
            span= t('auth.jwtFlow.steps.generateTokens.codeHeader.context')
          .code-content
            pre.
              {
                "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                "user": {
                  "id": "123",
                  "email": "usuario@example.com",
                  "roles": ["admin", "user"]
                }
              }

      .flow-step.mb-6(data-step="4")
        h3(class="font-semibold text-gray-900 mb-2")= t('auth.jwtFlow.steps.useToken.title')
        p.text-gray-600= t('auth.jwtFlow.steps.useToken.description')
        .code-block.mt-3
          .code-header
            span= t('auth.jwtFlow.steps.useToken.codeHeader.label')
            span= t('auth.jwtFlow.steps.useToken.codeHeader.context')
          .code-content
            pre.
              GET #{apiBasePath}/resources
              Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
              Content-Type: application/json

      .flow-step.mb-6(data-step="5")
        h3(class="font-semibold text-gray-900 mb-2")= t('auth.jwtFlow.steps.validateToken.title')
        p.text-gray-600
          != t('auth.jwtFlow.steps.validateToken.description')

      .flow-step.mb-6(data-step="6")
        h3(class="font-semibold text-gray-900 mb-2")= t('auth.jwtFlow.steps.refreshToken.title')
        p.text-gray-600= t('auth.jwtFlow.steps.refreshToken.description')
        .code-block.mt-3
          .code-header
            span= t('auth.jwtFlow.steps.refreshToken.codeHeader.label')
            span= t('auth.jwtFlow.steps.refreshToken.codeHeader.context')
          .code-content
            pre.
              POST #{apiBasePath}/auth/refresh-token
              Content-Type: application/json
              
              {
                "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
              }

  //- Verificar token
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.verifyToken.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")
        != t('auth.verifyToken.description')

      .code-block.mb-6
        .code-header
          span= t('auth.verifyToken.request.codeHeader.label')
          span= t('auth.verifyToken.request.codeHeader.context')
        .code-content
          pre.
            POST #{apiBasePath}/auth/verify-token
            Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
            Content-Type: application/json

      .code-block
        .code-header
          span= t('auth.verifyToken.response.codeHeader.label')
          span= t('auth.verifyToken.response.codeHeader.context')
        .code-content
          pre.
            {
              "message": "Token is valid",
              "user": {
                "id": "123",
                "email": "usuario@example.com",
                "roles": ["admin", "user"]
              }
            }

  //- Jitter no JWT
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.jitter.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")
        != t('auth.jitter.description')

      .code-block.mb-6
        .code-header
          span= t('auth.jitter.formula.codeHeader.label')
          span= t('auth.jitter.formula.codeHeader.context')
        .code-content
          pre.
            exp = now + baseTTL + random(0, JWT_JITTER_SECONDS)

      div(class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6")
        div.p-5.bg-indigo-50.rounded-lg.border.border-indigo-200
          h3(class="font-semibold text-indigo-900 mb-2")= t('auth.jitter.configuration.title')
          ul.space-y-2.text-sm.text-indigo-800
            each item in tm('auth.jitter.configuration.items')
              li • 
                != item
        div.p-5.bg-green-50.rounded-lg.border.border-green-200
          h3(class="font-semibold text-green-900 mb-2")= t('auth.jitter.example.title')
          p.text-sm.text-green-800.mb-2
            != t('auth.jitter.example.intro')
          ul.space-y-1.text-sm.text-green-800
            each item in tm('auth.jitter.example.items')
              li • #{item}

      .alert.alert-info
        svg(class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z")
        div
          p.font-medium.text-blue-900= t('auth.jitter.alert.title')
          p.text-sm.text-blue-700
            != t('auth.jitter.alert.description')

  //- Criação de conta
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.registration.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")
        != t('auth.registration.description')

      .code-block.mb-6
        .code-header
          span= t('auth.registration.request.codeHeader.label')
          span= t('auth.registration.request.codeHeader.context')
        .code-content
          pre.
            POST #{apiBasePath}/auth/register
            Content-Type: application/json

            {
              "firstName": "Jane",
              "lastName": "Smith",
              "username": "janesmith",
              "email": "jane.smith@example.com",
              "password": "Str0ng!P@ssword",
              "confirmPassword": "Str0ng!P@ssword"
            }

      .code-block.mb-6
        .code-header
          span= t('auth.registration.response.codeHeader.label')
          span= t('auth.registration.response.codeHeader.context')
        .code-content
          pre.
            {
              "user": {
                "id": "uuid-...",
                "firstName": "Jane",
                "lastName": "Smith",
                "username": "janesmith",
                "email": "jane.smith@example.com",
                "isActive": false,
                "roles": []
              },
              "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
              "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
              "message": "Registration successful. Please check your email to confirm your account."
            }

      h3(class="font-semibold text-gray-900 mb-3")= t('auth.registration.conflict.title')
      p(class="text-gray-700 mb-4")
        != t('auth.registration.conflict.description')
      .code-block.mb-6
        .code-header
          span= t('auth.registration.conflict.codeHeader.label')
          span= t('auth.registration.conflict.codeHeader.context')
        .code-content
          pre.
            {
              "statusCode": 409,
              "message": "A user with this email already exists",
              "error": "Conflict"
            }

      .alert.alert-info
        svg(class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z")
        div
          p.font-medium.text-blue-900= t('auth.registration.alert.title')
          p.text-sm.text-blue-700
            != t('auth.registration.alert.description')

  //- Reset de senha
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.passwordReset.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-6")
        = t('auth.passwordReset.intro')

      h3(class="font-semibold text-gray-900 mb-3")= t('auth.passwordReset.step1.title')
      .code-block.mb-6
        .code-header
          span= t('auth.passwordReset.step1.request.codeHeader.label')
          span= t('auth.passwordReset.step1.request.codeHeader.context')
        .code-content
          pre.
            POST #{apiBasePath}/auth/forgot-password
            Content-Type: application/json

            {
              "email": "jane.smith@example.com"
            }

      .code-block.mb-6
        .code-header
          span= t('auth.passwordReset.step1.response.codeHeader.label')
          span= t('auth.passwordReset.step1.response.codeHeader.context')
        .code-content
          pre.
            {
              "message": "Password reset instructions sent to your email"
            }

      h3(class="font-semibold text-gray-900 mb-3")= t('auth.passwordReset.step2.title')
      p.text-gray-700.mb-3
        != t('auth.passwordReset.step2.description')
      .code-block.mb-6
        .code-header
          span= t('auth.passwordReset.step2.request.codeHeader.label')
          span= t('auth.passwordReset.step2.request.codeHeader.context')
        .code-content
          pre.
            POST #{apiBasePath}/auth/reset-password
            Content-Type: application/json

            {
              "token": "abc123def456...",
              "password": "NewStr0ng!P@ssword",
              "confirmPassword": "NewStr0ng!P@ssword"
            }

      .code-block
        .code-header
          span= t('auth.passwordReset.step2.response.codeHeader.label')
          span= t('auth.passwordReset.step2.response.codeHeader.context')
        .code-content
          pre.
            {
              "message": "Password reset successfully"
            }

  //- Sistema de Roles
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.roles.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-6")
        | #{t('auth.roles.description').split('{role}')[0]}
        code(class="px-2 py-1 bg-gray-100 rounded text-sm")= t('auth.roles.roleCode')
        | #{t('auth.roles.description').split('{role}')[1]}

      h3(class="font-semibold text-gray-900 mb-4")= t('auth.roles.suggestedRoles.title')
      p(class="text-gray-700 mb-4")
        != t('auth.roles.suggestedRoles.intro')
      div(class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6")
        div.p-4.bg-purple-50.rounded-lg.border.border-purple-200
          span.role-badge.role-super.mb-2 super
          p.text-sm.text-gray-700= t('auth.roles.suggestedRoles.super')
        div.p-4.bg-red-50.rounded-lg.border.border-red-200
          span.role-badge.role-admin.mb-2 admin
          p.text-sm.text-gray-700= t('auth.roles.suggestedRoles.admin')
        div.p-4.bg-blue-50.rounded-lg.border.border-blue-200
          span.role-badge.role-manager.mb-2 manager
          p.text-sm.text-gray-700= t('auth.roles.suggestedRoles.manager')
        div.p-4.bg-green-50.rounded-lg.border.border-green-200
          span.role-badge.role-resident.mb-2 user
          p.text-sm.text-gray-700= t('auth.roles.suggestedRoles.user')

      h3(class="font-semibold text-gray-900 mb-4")= t('auth.roles.modelStructure.title')
      p(class="text-gray-700 mb-3")
        != t('auth.roles.modelStructure.description')
      .code-block.mb-6
        .code-header
          span= t('auth.roles.modelStructure.codeHeader.language')
          span= t('auth.roles.modelStructure.codeHeader.context')
        .code-content
          pre.
            import { Role } from '@modules/auth/enums/role.enum';

            enum Role {
              SUPER = 'super',
              ADMIN = 'admin',
              MANAGER = 'manager',
              USER = 'user',
            }

            interface User {
              id: string;
              email: string;
              roles: Role[];  #{t('auth.samples.arrayOfRoles')}
              // ... other fields
            }
            
            #{t('auth.samples.userExample')}
            const user = {
              id: "123",
              email: "admin@example.com",
              roles: [Role.ADMIN, Role.USER]  #{t('auth.samples.rolesDefinedByProject')}
            };

  //- Decorators e Guards
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.decoratorsAndGuards.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      h3(class="font-semibold text-gray-900 mb-4")= t('auth.decoratorsAndGuards.decorators.title')

      div(class="space-y-6")
        div
          h4(class="font-semibold text-gray-900 mb-2 flex items-center gap-2")
            code.text-indigo-600= t('auth.decoratorsAndGuards.decorators.public.label')
            span.text-gray-600= t('auth.decoratorsAndGuards.decorators.public.suffix')
          p.text-gray-700.mb-3
            = t('auth.decoratorsAndGuards.decorators.public.description')
          .code-block
            .code-header
              span= t('auth.decoratorsAndGuards.decorators.public.codeHeader.language')
              span= t('auth.decoratorsAndGuards.decorators.public.codeHeader.context')
            .code-content
              pre.
                import { Public } from '@modules/auth/decorators/public.decorator';
                
                @Controller('auth')
                export class AuthController {
                  @Public()  #{t('auth.samples.publicLogin')}
                  @Post('login')
                  async login(@Body() loginDto: LoginDto) {
                    return this.authService.login(loginDto);
                  }
                }

        div
          h4(class="font-semibold text-gray-900 mb-2 flex items-center gap-2")
            code.text-indigo-600= t('auth.decoratorsAndGuards.decorators.roles.label')
            span.text-gray-600= t('auth.decoratorsAndGuards.decorators.roles.suffix')
          p.text-gray-700.mb-3
            = t('auth.decoratorsAndGuards.decorators.roles.description')
          .code-block
            .code-header
              span= t('auth.decoratorsAndGuards.decorators.roles.codeHeader.language')
              span= t('auth.decoratorsAndGuards.decorators.roles.codeHeader.context')
            .code-content
              pre.
                import { Roles } from '@modules/auth/decorators/roles.decorator';
                import { Role } from '@modules/auth/enums/role.enum';
                
                @Controller('resources')
                export class ResourceController {
                  @Roles(Role.ADMIN, Role.SUPER)  #{t('auth.samples.rolesExample')}
                  @Get()
                  async findAll() {
                    return this.resourceService.findAll();
                  }
                  
                  @Roles(Role.ADMIN)
                  @Delete(':id')
                  async delete(@Param('id') id: string) {
                    return this.resourceService.delete(id);
                  }
                }

      h3(class="font-semibold text-gray-900 mb-4 mt-8")= t('auth.decoratorsAndGuards.guards.title')

      div(class="space-y-4")
        div
          h4(class="font-semibold text-gray-900 mb-2")
            code.text-indigo-600= t('auth.decoratorsAndGuards.guards.jwtAuthGuard.label')
          p.text-gray-700
            != t('auth.decoratorsAndGuards.guards.jwtAuthGuard.description')

        div
          h4(class="font-semibold text-gray-900 mb-2")
            code.text-indigo-600= t('auth.decoratorsAndGuards.guards.rolesGuard.label')
          p.text-gray-700
            != t('auth.decoratorsAndGuards.guards.rolesGuard.description')

  //- Exemplos Práticos
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.examples.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      h3(class="font-semibold text-gray-900 mb-4")= t('auth.examples.publicRoute.title')
      .code-block.mb-6
        .code-header
          span= t('auth.examples.publicRoute.codeHeader.language')
          span= t('auth.examples.publicRoute.codeHeader.context')
        .code-content
          pre.
            @Controller('auth')
            export class AuthController {
              @Public()  #{t('auth.samples.noAuthRequired')}
              @Post('register')
              async register(@Body() registerDto: RegisterDto) {
                return this.authService.register(registerDto);
              }
            }

      h3(class="font-semibold text-gray-900 mb-4")= t('auth.examples.protectedRoute.title')
      .code-block.mb-6
        .code-header
          span= t('auth.examples.protectedRoute.codeHeader.language')
          span= t('auth.examples.protectedRoute.codeHeader.context')
        .code-content
          pre.
            @Controller('resources')
            export class ResourceController {
              #{t('auth.samples.withoutPublic')}
              #{t('auth.samples.withoutRoles')}
              @Get('me')
              async getMine(@Request() req) {
                return this.resourceService.findByOwner(req.user.id);
              }
            }

      h3(class="font-semibold text-gray-900 mb-4")= t('auth.examples.roleBasedRoute.title')
      .code-block.mb-6
        .code-header
          span= t('auth.examples.roleBasedRoute.codeHeader.language')
          span= t('auth.examples.roleBasedRoute.codeHeader.context')
        .code-content
          pre.
            import { Role } from '@modules/auth/enums/role.enum';

            @Controller('resources')
            export class ResourceController {
              @Roles(Role.SUPER)  #{t('auth.samples.rolesExample')}
              @Get()
              async findAll() {
                return this.resourceService.findAll();
              }
              
              @Roles(Role.ADMIN)
              @Delete(':id')
              async delete(@Param('id') id: string) {
                return this.resourceService.delete(id);
              }
            }

      h3(class="font-semibold text-gray-900 mb-4")= t('auth.examples.multipleRoles.title')
      .code-block.mb-6
        .code-header
          span= t('auth.examples.multipleRoles.codeHeader.language')
          span= t('auth.examples.multipleRoles.codeHeader.context')
        .code-content
          pre.
            import { Role } from '@modules/auth/enums/role.enum';

            @Controller('resources')
            export class ResourceController {
              #{t('auth.samples.needsAdminOrManager')}
              @Roles(Role.ADMIN, Role.MANAGER)
              @Get('summary')
              async getSummary() {
                return this.resourceService.getSummary();
              }
              
              #{t('auth.samples.rolesUsesOr')}
              #{t('auth.samples.forAndCustomGuard')}
              @Roles(Role.SUPER)
              @Get('audit')
              async getAudit() {
                return this.resourceService.getAudit();
              }
            }

  //- Payload do Token
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.tokenPayload.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-6")
        != t('auth.tokenPayload.description')

      .code-block
        .code-header
          span= t('auth.tokenPayload.codeHeader.label')
          span= t('auth.tokenPayload.codeHeader.context')
        .code-content
          pre.
            {
              "id": "user123",
              "email": "usuario@example.com",
              "roles": ["admin", "user"],
              "iat": 1234567890,  #{t('auth.samples.issuedAt')}
              "exp": 1234571490   #{t('auth.samples.expiration')}
            }

  //- Configuração
  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('auth.configuration.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-6")
        != t('auth.configuration.description')

      .code-block.mb-6
        .code-header
          span= t('auth.configuration.codeHeader.label')
          span= t('auth.configuration.codeHeader.context')
        .code-content
          pre.
            #{t('auth.samples.jwtConfiguration')}
            JWT_SECRET=seu_jwt_secret_super_seguro_aqui
            JWT_EXPIRATION_TIME=1h
            JWT_REFRESH_SECRET=seu_refresh_secret_super_seguro
            JWT_REFRESH_EXPIRATION_TIME=7d
            JWT_JITTER_SECONDS=60
            
            #{t('auth.samples.bcryptConfiguration')}
            BCRYPT_HASH_FACTOR=12

      .alert.alert-warning
        svg(class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z")
        div
