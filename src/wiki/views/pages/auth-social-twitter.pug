extends ../layouts/main

block content
  .mb-12
    .inline-flex.items-center.gap-2.px-3.py-1.bg-indigo-50.rounded-full.text-indigo-700.text-sm.font-medium.mb-4
      svg(class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")
      span= t('authSocialTwitter.badge')
    h1(class="text-4xl font-bold text-gray-900 mb-4")
      | #{t('authSocialTwitter.hero.titlePrefix')} 
      span.gradient-text= t('authSocialTwitter.hero.titleHighlight')
    p(class="text-xl text-gray-600 max-w-3xl")
      = t('authSocialTwitter.hero.subtitle')

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.overview.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-6")
        != t('authSocialTwitter.overview.description')
      ul.space-y-2.text-gray-700
        each item in tm('authSocialTwitter.overview.items')
          li • #{item}

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.console.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")
        != t('authSocialTwitter.console.description')
      ol(class="list-decimal list-inside space-y-2 text-gray-700")
        each item in tm('authSocialTwitter.console.steps')
          li= item

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.env.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")
        != t('authSocialTwitter.env.description')
      .code-block
        .code-header
          span= t('authSocialTwitter.env.codeHeader.label')
          span= t('authSocialTwitter.env.codeHeader.context')
        .code-content
          pre.
            TWITTER_AUTH_ENABLED=true
            TWITTER_CLIENT_ID=your-twitter-client-id
            TWITTER_CLIENT_SECRET=your-twitter-client-secret
            TWITTER_CALLBACK_URL=http://localhost:3000/api/v1/auth/twitter/callback
            TWITTER_REDIRECT_ALLOWLIST=myapp://success,http://localhost:5173/auth/callback
            TWITTER_OAUTH_DEFAULT_ROLES=
            # SESSION_SECRET=optional-session-secret

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.roles.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700")
        != t('authSocialTwitter.roles.description')

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.flow.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      ol(class="list-decimal list-inside space-y-2 text-gray-700")
        each item in tm('authSocialTwitter.flow.items')
          li= item

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.api.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8.space-y-8
      div
        h3(class="font-semibold text-gray-900 mb-2")= t('authSocialTwitter.api.start.title')
        p(class="text-gray-700 mb-3")
          != t('authSocialTwitter.api.start.description')
        .code-block.mb-2
          .code-header
            span= t('authSocialTwitter.api.start.codeHeader.label')
            span= t('authSocialTwitter.api.start.codeHeader.context')
          .code-content
            pre.
              GET #{apiBasePath}/auth/twitter?redirect=http%3A%2F%2Flocalhost%3A5173%2Fauth%2Fcallback
        p(class="text-sm text-gray-500")= t('authSocialTwitter.api.start.errors')

      div
        h3(class="font-semibold text-gray-900 mb-2")= t('authSocialTwitter.api.callback.title')
        p(class="text-gray-700 mb-3")
          != t('authSocialTwitter.api.callback.description')
        .code-block
          .code-header
            span= t('authSocialTwitter.api.callback.codeHeader.label')
            span= t('authSocialTwitter.api.callback.codeHeader.context')
          .code-content
            pre.
              GET #{apiBasePath}/auth/twitter/callback?code=TWITTER_AUTH_CODE&state=...
              → 302 Location: http://localhost:5173/auth/callback?code=EXCHANGE_CODE

      div
        h3(class="font-semibold text-gray-900 mb-2")= t('authSocialTwitter.api.exchange.title')
        p(class="text-gray-700 mb-3")
          != t('authSocialTwitter.api.exchange.description')
        .code-block.mb-4
          .code-header
            span= t('authSocialTwitter.api.exchange.requestHeader.label')
            span= t('authSocialTwitter.api.exchange.requestHeader.context')
          .code-content
            pre.
              POST #{apiBasePath}/auth/exchange
              Content-Type: application/json

              {
                "code": "EXCHANGE_CODE"
              }
        .code-block.mb-2
          .code-header
            span= t('authSocialTwitter.api.exchange.responseHeader.label')
            span= t('authSocialTwitter.api.exchange.responseHeader.context')
          .code-content
            pre.
              {
                "user": {
                  "id": "...",
                  "email": "user@x.com",
                  "firstName": "Jane",
                  "lastName": "Doe",
                  "roles": [],
                  "twitterId": "2244...",
                  "isActive": true
                },
                "accessToken": "eyJhbGciOiJIUzI1NiIs...",
                "refreshToken": "eyJhbGciOiJIUzI1NiIs..."
              }
        p(class="text-sm text-gray-500")= t('authSocialTwitter.api.exchange.errors')

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.web.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")
        != t('authSocialTwitter.web.description')
      .code-block.mb-6
        .code-header
          span= t('authSocialTwitter.web.startHeader.label')
          span= t('authSocialTwitter.web.startHeader.context')
        .code-content
          pre.
            const API = 'http://localhost:3000/api/v1';
            const redirect = encodeURIComponent(
              'http://localhost:5173/auth/callback'
            );

            #{t('authSocialTwitter.samples.fullPageRedirect')}
            window.location.href = `${API}/auth/twitter?redirect=${redirect}`;
      .code-block.mb-6
        .code-header
          span= t('authSocialTwitter.web.callbackHeader.label')
          span= t('authSocialTwitter.web.callbackHeader.context')
        .code-content
          pre.
            #{t('authSocialTwitter.samples.spaCallback')}
            const params = new URLSearchParams(window.location.search);
            const code = params.get('code');
            if (!code) throw new Error('Missing exchange code');

            const res = await fetch('http://localhost:3000/api/v1/auth/exchange', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ code }),
            });
            if (!res.ok) throw new Error(await res.text());

            const { user, accessToken, refreshToken } = await res.json();
            #{t('authSocialTwitter.samples.persistTokens')}
            sessionStorage.setItem('accessToken', accessToken);
            console.log('signed in', user.email);
      ul.space-y-2.text-gray-700
        each item in tm('authSocialTwitter.web.notes')
          li • #{item}

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.mobile.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")
        != t('authSocialTwitter.mobile.description')
      .code-block.mb-6
        .code-header
          span= t('authSocialTwitter.mobile.openHeader.label')
          span= t('authSocialTwitter.mobile.openHeader.context')
        .code-content
          pre.
            import * as Linking from 'expo-linking';
            import * as WebBrowser from 'expo-web-browser';

            const API = 'https://api.example.com/api/v1';
            const redirect = encodeURIComponent('myapp://success');

            async function signInWithTwitter() {
              const url = `${API}/auth/twitter?redirect=${redirect}`;
              await WebBrowser.openAuthSessionAsync(url, 'myapp://success');
            }
      .code-block.mb-6
        .code-header
          span= t('authSocialTwitter.mobile.handleHeader.label')
          span= t('authSocialTwitter.mobile.handleHeader.context')
        .code-content
          pre.
            import * as Linking from 'expo-linking';

            async function exchangeFromUrl(url) {
              const { queryParams } = Linking.parse(url);
              const code = queryParams?.code;
              if (!code) return;

              const res = await fetch(`${API}/auth/exchange`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code }),
              });
              const data = await res.json();
              #{t('authSocialTwitter.samples.tokenFields')}
              return data;
            }

            Linking.addEventListener('url', ({ url }) => {
              exchangeFromUrl(url);
            });
      ul.space-y-2.text-gray-700
        each item in tm('authSocialTwitter.mobile.notes')
          li • #{item}

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.security.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      ul.space-y-2.text-gray-700
        each item in tm('authSocialTwitter.security.items')
          li • #{item}

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.userModel.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      p(class="text-gray-700 mb-4")= t('authSocialTwitter.userModel.description')
      ul.space-y-2.text-gray-700
        each item in tm('authSocialTwitter.userModel.items')
          li • #{item}

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('authSocialTwitter.related.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      ul.space-y-3
        li
          a(href=wikiPath('/auth/social') class="text-indigo-600 hover:underline font-medium")= t('authSocialTwitter.related.social')
        li
          a(href=wikiPath('/auth/social/google') class="text-indigo-600 hover:underline font-medium")= t('authSocialTwitter.related.google')
        li
          a(href=wikiPath('/auth/social/facebook') class="text-indigo-600 hover:underline font-medium")= t('authSocialTwitter.related.facebook')
        li
          a(href=wikiPath('/auth') class="text-indigo-600 hover:underline font-medium")= t('authSocialTwitter.related.auth')
