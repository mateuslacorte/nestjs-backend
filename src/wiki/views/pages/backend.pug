extends ../layouts/main

block content
  .mb-12
    .inline-flex.items-center.gap-2.px-3.py-1.bg-indigo-50.rounded-full.text-indigo-700.text-sm.font-medium.mb-4
      svg(class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4")
      span= t('backend.badge')
    h1(class="text-4xl font-bold text-gray-900 mb-4")
      | #{t('backend.hero.titlePrefix')} 
      span.gradient-text= t('backend.hero.titleHighlight')
    p(class="text-xl text-gray-600 max-w-3xl")
      = t('backend.hero.subtitle')

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('backend.pages.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8.space-y-4
      a(href=wikiPath('/backend/install') class="block p-6 rounded-lg border border-indigo-200 bg-indigo-50 hover:border-indigo-400 transition-colors")
        h3(class="font-semibold text-indigo-900 mb-2")= t('backend.pages.install.title')
        p(class="text-sm text-indigo-800")
          = t('backend.pages.install.description')
      a(href=wikiPath('/users') class="block p-6 rounded-lg border border-purple-200 bg-purple-50 hover:border-purple-400 transition-colors")
        h3(class="font-semibold text-purple-900 mb-2")= t('backend.pages.users.title')
        p(class="text-sm text-purple-800")
          = t('backend.pages.users.description')

  section.mb-12
    h2(class="text-2xl font-bold text-gray-900 mb-6")= t('backend.shortcuts.title')
    .bg-white.rounded-xl.border.border-gray-200.p-8
      ul.space-y-2.text-gray-700
        li
          a(href=swaggerPath class="text-indigo-600 hover:underline font-mono text-sm")= swaggerPath
          span  — #{t('backend.shortcuts.items.swagger')}
        li
          a(href=healthPath class="text-indigo-600 hover:underline font-mono text-sm")= healthPath
          span  — #{t('backend.shortcuts.items.health')}
        li
          a(href=wikiPath('') class="text-indigo-600 hover:underline font-mono text-sm") /
          span  — #{t('backend.shortcuts.items.wiki')}
        li
          a(href=apiBasePath class="text-indigo-600 hover:underline font-mono text-sm")= apiBasePath
          span  — #{t('backend.shortcuts.items.api')}
        li
          a(href=wikiPath('/users') class="text-indigo-600 hover:underline font-mono text-sm") /users
          span  — #{t('backend.shortcuts.items.users')}
        li
          a(href="http://localhost:8025" target="_blank" class="text-indigo-600 hover:underline font-mono text-sm") http://localhost:8025
          span  — #{t('backend.shortcuts.items.mailhog')}
        li
          a(href="http://localhost:9009" target="_blank" class="text-indigo-600 hover:underline font-mono text-sm") http://localhost:9009
          span  — #{t('backend.shortcuts.items.graylog')}
